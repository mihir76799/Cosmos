<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_navy">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/space_navy"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/detail_image"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/space_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orbitron"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/detail_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/space_accent"
                    android:textSize="13sp"
                    android:paddingBottom="12dp" />

                <TextView
                    android:id="@+id/detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/space_text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:paddingBottom="16dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/space_card"
                    app:strokeColor="@color/space_gold"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Fun Fact"
                            android:textColor="@color/space_gold"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingBottom="8dp" />

                        <TextView
                            android:id="@+id/ai_response"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/space_text_primary"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.5" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btn_ask_ai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ask AI"
                    android:backgroundTint="@color/space_accent"
                    android:textColor="@color/space_black" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Share"
        app:srcCompat="@android:drawable/ic_menu_share"
        app:backgroundTint="@color/cosmic_purple"
        android:tint="@color/white"
        app:elevation="6dp"/>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabFavorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="88dp"
        android:contentDescription="Favorite"
        app:srcCompat="@drawable/ic_favorite_border"
        app:backgroundTint="@color/space_card"
        app:tint="@color/space_gold"
        app:elevation="6dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>